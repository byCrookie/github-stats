{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group all minor/patch updates for auto-merge",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "Require manual approval for major version bumps",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ],
  "timezone": "Europe/Zurich",
  "schedule": ["at any time"],
  "dependencyDashboard": true,
  "minimumReleaseAge": "14 days",
  "prCreation": "not-pending",
  "internalChecksFilter": "strict",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "platformAutomerge": true
  },
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "ignoreTests": true
}
